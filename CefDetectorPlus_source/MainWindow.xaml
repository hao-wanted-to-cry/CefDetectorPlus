<?xml version="1.0" encoding="utf-8"?>
<Window x:Class="GoodNewsBrowserAppDetector.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:Microsoft.UI.Xaml.Controls"
        Title="CefDetectorX">

    <Grid>
        <!-- 背景图片 -->
        <Image x:Name="BgImage" Stretch="Fill" />

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- 标题区域 -->
            <Grid x:Name="TitleArea" Grid.Row="0" Margin="20,130,20,16">
                <Grid x:Name="TitleGrid" HorizontalAlignment="Center" Visibility="Visible">
                    <TextBlock x:Name="TitleStroke1" Text=""
                               FontFamily="Microsoft YaHei" FontSize="26" FontWeight="Bold"
                               Foreground="White" TextAlignment="Center" TextWrapping="Wrap"
                               Margin="-1,-1,0,0" />
                    <TextBlock x:Name="TitleStroke2" Text=""
                               FontFamily="Microsoft YaHei" FontSize="26" FontWeight="Bold"
                               Foreground="White" TextAlignment="Center" TextWrapping="Wrap"
                               Margin="1,-1,0,0" />
                    <TextBlock x:Name="TitleStroke3" Text=""
                               FontFamily="Microsoft YaHei" FontSize="26" FontWeight="Bold"
                               Foreground="White" TextAlignment="Center" TextWrapping="Wrap"
                               Margin="-1,1,0,0" />
                    <TextBlock x:Name="TitleStroke4" Text=""
                               FontFamily="Microsoft YaHei" FontSize="26" FontWeight="Bold"
                               Foreground="White" TextAlignment="Center" TextWrapping="Wrap"
                               Margin="1,1,0,0" />
                    <TextBlock x:Name="TitleText"
                               FontFamily="Microsoft YaHei" FontSize="26" FontWeight="Bold"
                               Foreground="#4169E1" TextAlignment="Center" TextWrapping="Wrap" />
                </Grid>
            </Grid>

            <!-- 卡片列表（虚拟化 ItemsRepeater） -->
            <ScrollViewer x:Name="MainScrollViewer"
                          Grid.Row="1"
                          HorizontalScrollBarVisibility="Disabled"
                          VerticalScrollBarVisibility="Auto"
                          Padding="32,8,32,8"
                          UseLayoutRounding="False"
                          ViewChanging="ScrollViewer_ViewChanging"
                          ViewChanged="ScrollViewer_ViewChanged">
                <ItemsRepeater x:Name="AppsRepeater"
                               VerticalCacheLength="2"
                               HorizontalCacheLength="2">
                    <ItemsRepeater.Layout>
                        <controls:UniformGridLayout
                            MinColumnSpacing="12"
                            MinRowSpacing="12"
                            MinItemWidth="140"
                            MinItemHeight="155"
                            ItemsJustification="Center" />
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate>
                            <!-- 卡片边框 -->
                            <!-- 移除 BitmapCache 以支持 BrushTransition 淡入淡出动画 -->
                            <!-- 降低白色不透明度，增强透明玻璃感 -->
                            <Border x:Name="CardBorder"
                                    Width="140"
                                    CornerRadius="12"
                                    Padding="14,18"
                                    BorderThickness="1"
                                    BorderBrush="#66FFFFFF"
                                    ToolTipService.ToolTip="{Binding TooltipText}"
                                    PointerEntered="Card_PointerEntered"
                                    PointerExited="Card_PointerExited"
                                    PointerCaptureLost="Card_PointerExited"
                                    PointerCanceled="Card_PointerExited"
                                    PointerReleased="Card_PointerReleased"
                                    Tapped="Card_Tapped">
                                <!-- 背景色过渡动画（BrushTransition 要求创建新 Brush 实例才能触发） -->
                                <Border.BackgroundTransition>
                                    <BrushTransition Duration="0:0:0.25" />
                                </Border.BackgroundTransition>
                                <!-- 正常态：18% 不透明度白色，更透明更有高级感 -->
                                <Border.Background>
                                    <SolidColorBrush Color="#2DFFFFFF" />
                                </Border.Background>
                                <StackPanel HorizontalAlignment="Center" Spacing="6">
                                    <Image Source="{Binding IconSource}"
                                           Width="40" Height="40"
                                           HorizontalAlignment="Center" />
                                    <TextBlock Text="{Binding DisplayName}"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="13" FontWeight="Bold"
                                               Foreground="{Binding NameForeground}"
                                               TextAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               MaxLines="2" />
                                    <TextBlock Text="{Binding EngineType}"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="12" FontWeight="Light"
                                               Foreground="#555555"
                                               TextAlignment="Center"
                                               MaxLines="1" />
                                    <TextBlock Text="{Binding SizeDisplay}"
                                               FontFamily="Microsoft YaHei"
                                               FontSize="12" FontWeight="Normal"
                                               Foreground="#555555"
                                               TextAlignment="Center" />
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </ScrollViewer>

            <!-- 底部音乐控制栏（毛玻璃材质，右下角） -->
            <Grid x:Name="MusicControlBar" Grid.Row="2"
                  HorizontalAlignment="Right" VerticalAlignment="Bottom"
                  Margin="0,0,24,16">
                <Border x:Name="MusicControlBorder"
                        CornerRadius="20" Padding="10,6,12,6"
                        BorderThickness="1" BorderBrush="#40FFFFFF"
                        Background="#99FFFFFF">
                    <Grid Height="32">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" MinWidth="90" MaxWidth="200" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- 播放/暂停按钮（Timer 手动 fade Opacity） -->
                        <Grid x:Name="PlayPauseBtn" Grid.Column="0"
                              Width="32" Height="32"
                              Background="Transparent"
                              Tapped="PlayPauseBtn_Tapped"
                              PointerEntered="PlayPauseBtn_PointerEntered"
                              PointerExited="PlayPauseBtn_PointerExited"
                              PointerPressed="PlayPauseBtn_PointerPressed"
                              PointerReleased="PlayPauseBtn_PointerReleased"
                              PointerCaptureLost="PlayPauseBtn_PointerReleased">
                            <Border x:Name="PlayPauseHover"
                                    Width="32" Height="32" CornerRadius="16"
                                    Background="#20000000" Opacity="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <FontIcon x:Name="PlayPauseIcon"
                                      Glyph="&#xE768;" FontSize="15"
                                      Foreground="#000000"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <!-- 时间显示 -->
                        <TextBlock x:Name="TimeText" Grid.Column="1"
                                   Text="0:00 / 0:00"
                                   FontFamily="Consolas" FontSize="11"
                                   Foreground="#000000"
                                   VerticalAlignment="Center" Margin="6,0,0,0"
                                   MinWidth="76" TextAlignment="Center" />

                        <!-- 自定义进度条：Grid + Pointer 事件，绕过 Slider Thumb 问题 -->
                        <Grid x:Name="ProgressTrack" Grid.Column="2"
                              MinWidth="30" Height="20" VerticalAlignment="Center" Margin="10,0,2,0"
                              PointerPressed="ProgressTrack_PointerPressed"
                              PointerMoved="ProgressTrack_PointerMoved"
                              PointerReleased="ProgressTrack_PointerReleased"
                              PointerCaptureLost="ProgressTrack_PointerReleased"
                              PointerEntered="ProgressTrack_Entered"
                              PointerExited="ProgressTrack_Exited"
                              Background="Transparent">
                            <!-- 轨道背景（未播放部分） -->
                            <Border x:Name="ProgressTrackBg" Height="4"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    CornerRadius="2" Background="#25000000" />
                            <!-- 已播放部分 -->
                            <Border x:Name="ProgressFill" Height="4" Width="0"
                                    VerticalAlignment="Center" CornerRadius="2"
                                    HorizontalAlignment="Left" Background="#000000" />
                            <!-- 拖拽圆点 -->
                            <Ellipse x:Name="ProgressThumb" Width="14" Height="14"
                                     VerticalAlignment="Center" HorizontalAlignment="Left"
                                     Margin="-7,0,0,0" Fill="#000000" />
                        </Grid>

                        <!-- 音量图标 -->
                        <Grid x:Name="VolumeIconBtn" Grid.Column="3"
                              Width="24" Height="24"
                              Background="Transparent"
                              Tapped="VolumeIconBtn_Tapped"
                              PointerEntered="VolumeIconBtn_PointerEntered"
                              PointerExited="VolumeIconBtn_PointerExited"
                              PointerPressed="VolumeIconBtn_PointerPressed"
                              PointerReleased="VolumeIconBtn_PointerReleased"
                              PointerCaptureLost="VolumeIconBtn_PointerReleased">
                            <Border x:Name="VolumeHover"
                                    Width="24" Height="24" CornerRadius="12"
                                    Background="#20000000" Opacity="0"
                                    HorizontalAlignment="Center" VerticalAlignment="Center" />
                            <FontIcon x:Name="VolumeIcon"
                                      Glyph="&#xE995;" FontSize="13"
                                      Foreground="#000000"
                                      HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Grid>

                        <!-- 自定义音量条 -->
                        <Grid x:Name="VolumeTrack" Grid.Column="4"
                              Height="20" Width="50" VerticalAlignment="Center" Margin="2,0,0,0"
                              PointerPressed="VolumeTrack_PointerPressed"
                              PointerMoved="VolumeTrack_PointerMoved"
                              PointerReleased="VolumeTrack_PointerReleased"
                              PointerCaptureLost="VolumeTrack_PointerReleased"
                              PointerEntered="VolumeTrack_Entered"
                              PointerExited="VolumeTrack_Exited"
                              Background="Transparent">
                            <Border x:Name="VolumeTrackBg" Height="4"
                                    HorizontalAlignment="Stretch" VerticalAlignment="Center"
                                    CornerRadius="2" Background="#25000000" />
                            <Border x:Name="VolumeFill" Height="4" Width="25"
                                    VerticalAlignment="Center" CornerRadius="2"
                                    HorizontalAlignment="Left" Background="#000000" />
                            <Ellipse x:Name="VolumeThumb" Width="14" Height="14"
                                     VerticalAlignment="Center" HorizontalAlignment="Left"
                                     Margin="18,0,0,0" Fill="#000000" />
                        </Grid>
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>